BS_:

BU_: Hand Robot


BO_ 256 CAN_MSG_SENSOR: 8 Hand
 SG_ Roll : 0|16@1- (0.1,0) [-180|180] "deg" Robot
 SG_ Pitch : 16|16@1- (0.1,0) [-180|180] "deg" Robot
 SG_ HeightSwitch : 32|8@1+ (1,0) [0|2] "" Robot
 SG_ Reserved : 40|16@1+ (1,0) [0|65535] "" Robot
 SG_ Checksum : 56|8@1+ (1,0) [0|255] "" Robot

BO_ 257 CAN_MSG_FLEX: 8 Hand
 SG_ Flex1 : 0|16@1+ (1,0) [0|4095] "count" Robot
 SG_ Flex2 : 16|16@1+ (1,0) [0|4095] "count" Robot
 SG_ Reserved : 32|24@1+ (1,0) [0|16777215] "" Robot
 SG_ Checksum : 56|8@1+ (1,0) [0|255] "" Robot

BO_ 258 CAN_MSG_ERROR_HAND: 8 Robot
 SG_ Byte0 : 0|8@1+ (1,0) [0|255] "" Hand
 SG_ Byte1 : 8|8@1+ (1,0) [0|255] "" Hand
 SG_ Byte2 : 16|8@1+ (1,0) [0|255] "" Hand
 SG_ Byte3 : 24|8@1+ (1,0) [0|255] "" Hand
 SG_ Byte4 : 32|8@1+ (1,0) [0|255] "" Hand
 SG_ Byte5 : 40|8@1+ (1,0) [0|255] "" Hand
 SG_ Byte6 : 48|8@1+ (1,0) [0|255] "" Hand
 SG_ Byte7 : 56|8@1+ (1,0) [0|255] "" Hand

BO_ 512 CAN_MSG_SERVO_DBG: 8 Robot
 SG_ Servo1 : 0|8@1- (1,0) [-90|90] "deg" Vector__XXX
 SG_ Servo2 : 8|8@1- (1,0) [-90|90] "deg" Vector__XXX
 SG_ Servo3 : 16|8@1- (1,0) [-90|90] "deg" Vector__XXX
 SG_ Servo4 : 24|8@1- (1,0) [-90|90] "deg" Vector__XXX
 SG_ Servo5 : 32|8@1- (1,0) [-90|90] "deg" Vector__XXX
 SG_ Servo6 : 40|8@1- (1,0) [-90|90] "deg" Vector__XXX
 SG_ Reserved : 48|8@1+ (1,0) [0|255] "" Vector__XXX
 SG_ Checksum : 56|8@1+ (1,0) [0|255] "" Vector__XXX

BO_ 513 CAN_MSG_ERROR_ROBOT: 8 Hand
 SG_ Byte0 : 0|8@1+ (1,0) [0|255] "" Robot
 SG_ Byte1 : 8|8@1+ (1,0) [0|255] "" Robot
 SG_ Byte2 : 16|8@1+ (1,0) [0|255] "" Robot
